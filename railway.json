{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "npx prisma db push --accept-data-loss && cd .next/standalone && HOSTNAME=0.0.0.0 node server.js",
    "restartPolicyType": "ON_FAILURE"
  },
  "crons": [
    {
      "schedule": "0 8 * * *",
      "command": "curl -s -o /dev/null -w '%{http_code}' -H 'Authorization: Bearer $CRON_SECRET' $NEXT_PUBLIC_BASE_URL/api/cron/reminders"
    }
  ]
}
