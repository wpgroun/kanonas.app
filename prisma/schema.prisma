// schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// =======================
// SYSTEM & SAAS CORE
// =======================

model PlatformSettings {
  id               String   @id @default("singleton")
  vivaClientId     String?
  vivaClientSecret String?
  vivaSourceCode   String?
  vivaWebhookKey   String?
  vivaDemo         Boolean  @default(true)
  bankIban         String?
  bankBeneficiary  String?
  bankName         String?
  smtpHost         String?
  smtpPort         Int?
  smtpUser         String?
  smtpPass         String?
  yubotoApiKey     String?
  yubotoSenderId   String?
  updatedAt        DateTime @updatedAt
}

model Metropolis {
  id      String           @id @default(cuid())
  name    String
  // Unique short code used in URLs and reports (e.g. "thessaloniki")
  slug    String?          @unique
  city    String?
  email   String?
  phone   String?
  temples Temple[]
  // Users with Metropolis-level access (read-only across all temples)
  users   MetropolisUser[]

  centralEvents CentralEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Metropolis-level admin users (supervisory access, read-only)
model MetropolisUser {
  id           String     @id @default(cuid())
  metropolisId String
  metropolis   Metropolis @relation(fields: [metropolisId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         String     @default("viewer") // "viewer", "admin"
  createdAt    DateTime   @default(now())

  @@unique([metropolisId, userId])
}

// =======================
// SUBSCRIPTION PLANS (admin-configurable)
// =======================

model SubscriptionPlan {
  id String @id @default(cuid())

  // e.g. "Ενορία Basic", "Ενορία Premium", "Μητρόπολη"
  name String @unique
  slug String @unique // "basic", "premium", "mitrópoli"

  // Pricing
  priceMonthly Float @default(0) // EUR per month
  priceYearly  Float @default(0) // EUR per year (discounted)

  // Metropolis plans are manually activated by super admin only
  isMetropolis Boolean @default(false)

  // Features included (stored as JSON array of feature keys)
  features String @default("[]") // JSON

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Temple {
  id           String      @id @default(cuid())
  // Every temple SHOULD belong to a Metropolis
  metropolisId String?
  metropolis   Metropolis? @relation(fields: [metropolisId], references: [id])
  name         String
  slug         String?     @unique // Δημόσιο URL για το mini-site του Ναού π.χ. "agios-nikolaos"
  taxId        String? // ΑΦΜ
  phoneNumber  String? // Τηλέφωνο Επικοινωνίας
  address      String?
  city         String?
  email        String?

  // Settings (stored as JSON for flexibility, e.g., smtpHost, smsToken, viberToken)
  settings String? @default("{}") // JSON string

  // SaaS Multi-tenancy relations
  subscriptionStatus  String    @default("active") // "active", "inactive", "trial"
  subscriptionPlan    String    @default("basic") // "basic", "premium"
  subscriptionStartDate DateTime?
  subscriptionEndDate DateTime?

  lat                 Float?
  lng                 Float?

  users        UserTemple[]
  parishioners Parishioner[]
  sacraments   Sacrament[]
  tokens       Token[]
  donations    Donation[]
  expenses     Expense[]
  budgets      Budget[]
  documents    Document[]
  docTemplates DocTemplate[]
  settingsDocs DocTemplateSetting[]
  diptychs     Diptych[]
  protocols    Protocol[]
  schedules    ServiceSchedule[]
  roles        Role[]
  assignments  Assignment[]
  vaultDocs    VaultDocument[]

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  beneficiaries       Beneficiary[]
  sissitioDays        SissitioDay[]
  inventoryItems      InventoryItem[]
  subscriptions       Subscription[]
  auditLogs           AuditLog[]
  financialYears      FinancialYear[]
  financialCategories FinancialCategory[]
  incomes             Income[]

  philoptochosMembers PhiloptochosMember[]
  bloodDonors         BloodDonor[]
  bloodDrives         BloodDrive[]
  assets              Asset[]
  centralEvents       CentralEvent[]

  deceasedPersons          DeceasedPerson[]
  kanbanTasks              KanbanTask[]
  citizenRequests          CitizenRequest[]
  parishionerRelationships ParishionerRelationship[]
  ecclesiasticalDivorces   EcclesiasticalDivorce[]
  prayerRequests           PrayerRequest[]
  ministries               Ministry[]
  volunteers               Volunteer[]
  youthPrograms            YouthProgram[]
  youthParticipants        YouthParticipant[]
  bookingSlots             BookingSlot[]

  // Sissitio Expanded
  sissitioRecipients       SissitioRecipient[]
  sissitioMenus            SissitioMenu[]
  sissitioRecipes          SissitioRecipe[]
  sissitioPortionLogs      SissitioPortionLog[]
  sissitioInventoryItems   SissitioInventoryItem[]

  // Camps
  campSessions             CampSession[]
  campCampers              CampCamper[]
}

model KanbanTask {
  id          String    @id @default(cuid())
  templeId    String
  temple      Temple    @relation(fields: [templeId], references: [id])
  title       String
  description String?
  status      String    @default("TODO") // TODO, IN_PROGRESS, DONE
  priority    String    @default("NORMAL") // LOW, NORMAL, HIGH
  assignee    String? // Name or ID of whoever is responsible
  dueDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String?
  firstName    String?
  lastName     String?

  // Super admin (Metropolis/Platform level)
  isSuperAdmin Boolean @default(false)

  // TOTP 2FA (Authenticator App)
  totpSecret       String?
  twoFactorEnabled Boolean @default(false)

  temples UserTemple[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  metropolisUsers MetropolisUser[]
  sessions        UserSession[]
  assignedRequests CitizenRequest[]
}

model UserSession {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent  String?
  ipAddress  String?
  lastActive DateTime @default(now())
  createdAt  DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model UserTemple {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id], onDelete: SetNull)

  isHeadPriest Boolean @default(false)
  status       String  @default("active") // active, pending, inactive

  // HR Details for Clergy & Staff
  ordinationDiaconate  DateTime?
  ordinationPriesthood DateTime?
  offikia              String?
  hireDate             DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, templeId])
}

model Role {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  name              String // e.g., "Γραμματεία", "Εφημέριος"
  // Permissions (Admin)
  canViewFinances   Boolean @default(false)
  canEditFinances   Boolean @default(false)
  canManageRequests Boolean @default(false) // Sacraments approvals
  canManageProtocol Boolean @default(false) // Protocol Book
  canManageRegistry Boolean @default(false) // Parishioner CRM
  canManageSchedule Boolean @default(false) // Calendars
  canManageAssets   Boolean @default(false) // Inventory Assets

  // Permissions (Philanthropy & Volunteering)
  canViewBeneficiaries   Boolean @default(false) // See names in daily sissitio
  canViewBeneficiaryDocs Boolean @default(false) // See Vault documents (e.g., E1)
  canManageBeneficiaries Boolean @default(false) // Edit beneficiary data
  canViewInventory       Boolean @default(false) // See Food Inventory
  canManageInventory     Boolean @default(false) // Add/Edit Food Inventory

  users UserTemple[]

  @@unique([templeId, name])
}

// =======================
// CRM (PARISHIONERS)
// =======================

model Parishioner {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  status      String    @default("active")
  email       String?
  firstName   String
  lastName    String
  fathersName String?
  mothersName String?
  phone       String?
  mobile      String?
  address     String?
  city        String?
  birthDate   DateTime?

  afm      String?
  idNumber String? // ADT

  profession   String?
  familyStatus String? // oik_katastasis
  isConvert    Boolean @default(false) // Ορθόδοξος εξ Ετεροδόξων

  roles String? // JSON array: '["enoriths", "psaltis"]'

  // Relations
  donations         Donation[]
  sacramentHistory  Sacrament[]
  ceremonyPersons   CeremonyPerson[]
  vaultDocs         VaultDocument[]
  bloodDonor        BloodDonor?

  // Παρακάτω προστίθενται τα relationships (Κουμπάροι, Ανάδοχοι κλπ)
  relationshipsAsSource ParishionerRelationship[] @relation("SourceRelation")
  relationshipsAsTarget ParishionerRelationship[] @relation("TargetRelation")
  divorces              EcclesiasticalDivorce[]
  prayerRequests        PrayerRequest[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  beneficiary    Beneficiary?
  deceasedRecord DeceasedPerson?

  @@unique([email, templeId])
}

// Πίνακας για Συγγένειες και Πνευματικές Σχέσεις (Godparents, Koombaroi, etc)
model ParishionerRelationship {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  sourceId String
  source   Parishioner @relation("SourceRelation", fields: [sourceId], references: [id], onDelete: Cascade)

  targetId String
  target   Parishioner @relation("TargetRelation", fields: [targetId], references: [id], onDelete: Cascade)

  relationshipType String // "GODPARENT", "GODCHILD", "SPOUSE", "CHILD", "PARENT", "BESTMAN"

  createdAt DateTime @default(now())

  @@unique([sourceId, targetId, relationshipType])
}

// =======================
// SACRAMENTS WORKFLOW
// =======================

model Token {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  tokenStr    String @unique // The unique hash for the user link
  serviceType String // e.g. 'gamos', 'vaptisi'
  status      String @default("pending") // pending, docs_generated, completed

  customerName  String?
  customerEmail String?
  ceremonyDate  DateTime?

  assignedPriest   String?
  assignedPsaltis  String?
  assignedNeokomos String?

  protocolNumber String?
  bookNumber     String?

  submissionComplete Boolean @default(false)

  ceremonyMeta CeremonyMeta?
  persons      CeremonyPerson[]
  documents    Document[]
  assignments  Assignment[]
  vaultDocs    VaultDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CeremonyPerson {
  id      String @id @default(cuid())
  tokenId String
  token   Token  @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  role String // groom, bride, koumbaros, child...

  firstName   String
  lastName    String
  fathersName String?
  mothersName String?

  parishionerId String?
  parishioner   Parishioner? @relation(fields: [parishionerId], references: [id], onDelete: SetNull)

  idNumber String?
  afm      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CeremonyMeta {
  id      String @id @default(cuid())
  tokenId String @unique
  token   Token  @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  dataJson String @default("{}")
}

// Generated / Uploaded Documents
model Document {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  tokenId String?
  token   Token?  @relation(fields: [tokenId], references: [id], onDelete: SetNull)

  docType     String // 'aitisi', 'pistopoiitiko', 'id_upload'
  storagePath String // URL to storage
  fileName    String

  createdAt DateTime @default(now())
}


// =======================
// BOOKING SLOTS (CALENDLY STYLE)
// =======================
model BookingSlot {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  // e.g. "GAMOS", "BAPTISM"
  serviceType String 
  
  // The start time of the slot
  startTime DateTime
  // The estimated end time
  endTime   DateTime?

  // Optionally specify which priest is handling it
  priestId String?

  // Is it booked? If booked, connectTokenHash points to the connect Request
  isBooked Boolean @default(false)
  connectTokenHash String? @unique

  citizenRequest CitizenRequest?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =======================
// TEMPLATES

// =======================

model DocTemplate {
  id       String  @id @default(cuid())
  templeId String? // If null, it's a global SaaS template!
  temple   Temple? @relation(fields: [templeId], references: [id], onDelete: Cascade)

  docType     String
  nameEl      String
  visibility  String  @default("internal") // "citizen" = sent to citizen, "internal" = staff only, "metropolis" = sent to metropolis
  htmlContent String?
  fileUrl     String?
  context     String?
  conditionRules String? // JSON logic mapping IF variables THEN render

  settingsDocs DocTemplateSetting[]

  createdAt DateTime @default(now())
}

model DocTemplateSetting {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  templateId String
  template   DocTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  isEnabled    Boolean @default(true)
  customHeader String?
}

// =======================
// FINANCES (ENTERPRISE)
// =======================

model FinancialYear {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  year     Int
  isSealed Boolean   @default(false)
  sealedAt DateTime?
  sealedBy String? // user ID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([templeId, year])
}

model FinancialCategory {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  name String // e.g. "Παγκάρι", "Μισθοδοσία"
  type String // "INCOME" or "EXPENSE"

  // Linkages
  expenses Expense[]
  incomes  Income[]
  budgets  Budget[]

  @@unique([templeId, name, type])
}

model Income {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  categoryId String
  category   FinancialCategory @relation(fields: [categoryId], references: [id])

  amount        Float
  date          DateTime @default(now())
  receiptNumber String?
  description   String?
  donorName     String?

  createdAt DateTime @default(now())
}

model Donation {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  parishionerId String?
  parishioner   Parishioner? @relation(fields: [parishionerId], references: [id], onDelete: SetNull)

  donorName     String?
  amount        Float
  purpose       String?
  date          DateTime @default(now())
  receiptNumber String?

  createdAt DateTime @default(now())
}

model Sacrament {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  parishionerId String
  parishioner   Parishioner @relation(fields: [parishionerId], references: [id], onDelete: Cascade)

  sacramentType String
  sacramentDate DateTime?
  notes         String?

  createdAt DateTime @default(now())
}

model EcclesiasticalDivorce {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  parishionerId String
  parishioner   Parishioner @relation(fields: [parishionerId], references: [id], onDelete: Cascade)

  protocolNumber       String? // Aριθμός πρωτοκόλλου
  civilDivorceDecision String? // Αριθμός και Πρωτοδικείο λύσης αστικού γάμου
  civilDivorceDate     DateTime? // Ημερομηνία Αστικού Διαζυγίου
  exSpouseName         String // Όνομα του/της πρώην συζύγου
  issuedDate           DateTime  @default(now()) // Ημεροχρονολογία έκδοσης εκκλησιαστικού διαζυγίου
  reason               String? // Αιτιολογία ή σημειώσεις

  createdAt DateTime @default(now())
}

model Expense {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  categoryId String?
  category   FinancialCategory? @relation(fields: [categoryId], references: [id])

  purpose       String
  amount        Float
  date          DateTime @default(now())
  receiptNumber String?
  vendor        String?

  createdAt DateTime @default(now())
}

model Budget {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  year       Int
  categoryId String
  category   FinancialCategory @relation(fields: [categoryId], references: [id])

  estimatedAmt Float
  actualAmt    Float @default(0) // Automatically updated

  createdAt DateTime @default(now())

  @@unique([templeId, year, categoryId])
}

// =======================
// PHILANTHROPY & SISSITIO (ΦΙΛΟΠΤΩΧΟ)
// =======================

model Beneficiary {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  // Optional linkage to the Parishioner Registry
  parishionerId String?      @unique
  parishioner   Parishioner? @relation(fields: [parishionerId], references: [id], onDelete: SetNull)

  firstName String
  lastName  String
  address   String?
  phone     String?
  afm       String? // Global AFM duplicate detection flag

  // Criteria
  familyMembers Int   @default(1)
  monthlyIncome Float @default(0)
  criteriaScore Int   @default(0) // Computed score 0-100

  // Sissitio Data
  status       String  @default("active") // active, pending, inactive
  portions     Int     @default(1)
  medicalNotes String? // Allergies, diabetes etc.

  assistances Assistance[]
  documents   BeneficiaryDoc[]
  attendances SissitioAttendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BeneficiaryDoc {
  id            String      @id @default(cuid())
  beneficiaryId String
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)

  docType    String // e.g. "Ταυτότητα", "Εκκαθαριστικό"
  storageUrl String

  createdAt DateTime @default(now())
}

// Financial or Material aid given (other than daily sissitio)
model Assistance {
  id            String      @id @default(cuid())
  beneficiaryId String
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)

  type        String // e.g. "money", "clothes", "dei", "rent"
  description String?
  amount      Float? // Equivalent value in EUR if applicable

  dateGiven DateTime @default(now())
}

// The daily operation of Sissitio
model SissitioDay {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  date          DateTime // e.g. "2026-04-10"
  menu          String? // What was cooked (e.g. "Φακές")
  totalPortions Int      @default(0)

  attendances SissitioAttendance[]

  @@unique([templeId, date])
}

model SissitioAttendance {
  id            String      @id @default(cuid())
  sissitioDayId String
  sissitioDay   SissitioDay @relation(fields: [sissitioDayId], references: [id], onDelete: Cascade)

  beneficiaryId String
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)

  portionsTaken Int     @default(1)
  wasAbsent     Boolean @default(false)

  @@unique([sissitioDayId, beneficiaryId])
}

// Pantry / Inventory
model InventoryItem {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  name     String
  category String // food, medicine, hygiene
  unit     String // kg, τεμάχια, λίτρα
  quantity Float  @default(0)
  minStock Float  @default(0)

  expiryDate DateTime?

  lastRestockDate DateTime?
}

// =======================
// DIPTYCHS (ΔΙΠΤΥΧΑ - ΜΝΗΜΟΝΕΥΣΗ)
// =======================

model Diptych {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  type String // "ygeias" or "anapauseos"
  name String // The first name to commemorate

  isActive Boolean @default(true) // Set to false after Proskomidi if they clear the list
  notes    String?

  submittedBy String?
  email       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =======================
// PROTOCOL (ΠΡΩΤΟΚΟΛΛΟ)
// =======================

model Protocol {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  owner  String @default("TEMPLE") // TEMPLE, PHILOPTOCHOS
  number Int
  year   Int

  direction String // "IN" (Εισερχόμενο) or "OUT" (Εξερχόμενο)
  subject   String // Θέμα
  sender    String? // Αποστολέας
  receiver  String? // Παραλήπτης

  tokenId String? // Optional connection to a Sacrament request

  // Web Scanner attachment
  fileUrl  String?
  fileName String?

  date DateTime @default(now())

  @@unique([templeId, owner, year, number])
}

// =======================
// SCHEDULE (ΠΡΟΓΡΑΜΜΑ ΑΚΟΛΟΥΘΙΩΝ)
// =======================

model ServiceSchedule {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  date        DateTime
  title       String
  description String?
  isMajor     Boolean  @default(false)

  createdAt DateTime @default(now())
}

// =======================
// ASSETS (ΠΕΡΙΟΥΣΙΟΛΟΓΙΟ)
// =======================

model Asset {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  owner     String @default("TEMPLE") // TEMPLE, PHILOPTOCHOS
  assetType String @default("MOVABLE") // MOVABLE, IMMOVABLE

  name            String
  category        String // e.g. "RELIC", "VESSEL", "APARTMENT", "LAND"
  description     String?
  location        String?
  acquisitionDate DateTime?
  estimatedValue  Float?
  imageUrl        String?
  status          String    @default("ACTIVE") // "ACTIVE", "MAINTENANCE", "INACTIVE"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =======================
// PHILOPTOCHOS BOARD
// =======================
model PhiloptochosMember {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String
  role      String // Πρόεδρος, Αντιπρόεδρος, Ταμίας, Μέλος
  startDate DateTime
  endDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =======================
// BLOOD BANK (ΑΙΜΟΔΟΣΙΑ)
// =======================

model BloodDonor {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  parishionerId String?      @unique
  parishioner   Parishioner? @relation(fields: [parishionerId], references: [id], onDelete: SetNull)

  firstName String
  lastName  String
  phone     String?
  email     String?
  address   String?
  bloodType String // "A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"

  dateOfBirth   DateTime?
  gender        String?   // "M" | "F"
  hemoglobin    Float?    // g/dL — eligibility threshold

  lastDonation     DateTime?
  nextEligibleDate DateTime? // auto-calculated: lastDonation + 56 days
  totalDonations   Int       @default(0)
  isActive         Boolean   @default(true)
  notes            String?

  donations     BloodDonation[]
  driveSignups  BloodDriveParticipant[]

  createdAt DateTime @default(now())
}

model BloodDonation {
  id      String     @id @default(cuid())
  donorId String
  donor   BloodDonor @relation(fields: [donorId], references: [id], onDelete: Cascade)

  date            DateTime
  hospital        String?
  certificateNo   String? // AIM-2026-001
  hemoglobinLevel Float?
  units           Float   @default(1) // φιάλες
  notes           String?

  bloodDrive   BloodDrive? @relation(fields: [bloodDriveId], references: [id])
  bloodDriveId String?

  createdAt DateTime @default(now())
}

model BloodDriveParticipant {
  id      String     @id @default(cuid())
  driveId String
  drive   BloodDrive @relation(fields: [driveId], references: [id], onDelete: Cascade)
  donorId String
  donor   BloodDonor @relation(fields: [donorId], references: [id], onDelete: Cascade)

  donated   Boolean  @default(false)
  notes     String?
  signedUp  DateTime @default(now())

  @@unique([driveId, donorId])
}

// =======================
// ASSIGNMENTS (ΑΝΑΘΕΣΕΙΣ ΠΡΟΣΩΠΙΚΟΥ)
// =======================

model Assignment {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  date        DateTime
  serviceType String // "GAMOS", "VAPTISI", "LITURGY", "MNIMOSINO", "OTHER"

  tokenId String?
  token   Token?  @relation(fields: [tokenId], references: [id], onDelete: SetNull)

  priest   String?
  psaltis  String?
  neokomos String?
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =======================
// VAULT (ΑΡΧΕΙΟΘΗΚΗ ΕΓΓΡΑΦΩΝ)
// =======================

model VaultDocument {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  tokenId String?
  token   Token?  @relation(fields: [tokenId], references: [id], onDelete: SetNull)

  parishionerId String?
  parishioner   Parishioner? @relation(fields: [parishionerId], references: [id], onDelete: SetNull)

  docType  String // "TAUTOTITA", "DIAZEYKTIRIO", "PISTOPOIITIKO", "ALLO"
  label    String? // Φιλικό όνομα
  fileName String
  filePath String
  fileSize Int     @default(0)
  mimeType String  @default("application/octet-stream")

  uploadedAt DateTime @default(now())
}

// =======================
// SUBSCRIPTIONS
// =======================

model Subscription {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  planId String
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  status String @default("active") // "active", "cancelled", "past_due", "trialing", "pending_manual"

  // Billing period
  billingCycle String @default("monthly") // "monthly" or "yearly"

  // Viva Wallet fields (null for manually activated subscriptions like Metropolis)
  vivaOrderCode     String?   @unique
  vivaTransactionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?

  // Manual activation (for Metropolis plans)
  activatedBy String? // userId of super admin who activated
  activatedAt DateTime?
  expiresAt   DateTime? // for manually set expiry

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([templeId, status]) // Only one active subscription per temple
}

// =======================
// AUDIT LOG
// =======================

model AuditLog {
  id       String  @id @default(cuid())
  templeId String?
  temple   Temple? @relation(fields: [templeId], references: [id], onDelete: SetNull)

  userId     String? // Who performed the action
  userEmail  String?
  action     String // e.g. "CREATE_PARISHIONER", "DELETE_TOKEN", "LOGIN"
  entityType String? // e.g. "Parishioner", "Token", "Donation"
  entityId   String? // The ID of the affected entity
  detail     String? // Human-readable description
  ipAddress  String?

  createdAt DateTime @default(now())
}

// =======================
// DECEASED REGISTRY (ΜΗΤΡΩΟ ΚΕΚΟΙΜΗΜΕΝΩΝ & ΜΝΗΜΟΣΥΝΑ)
// =======================

model DeceasedPerson {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  parishionerId String?      @unique
  parishioner   Parishioner? @relation(fields: [parishionerId], references: [id], onDelete: SetNull)

  firstName      String
  lastName       String
  fathersName    String?
  dateOfDeath    DateTime
  dateOfFuneral  DateTime?
  placeOfFuneral String? // e.g., Νεκροταφείο Ζωγράφου
  graveDetails   String? // e.g., Τομέας Β, Τάφος 42

  nextOfKinName  String?
  nextOfKinPhone String?
  causeOfDeath   String?

  bookNumber String? // Αριθμός Πράξης

  memorials MemorialService[]

  createdAt DateTime @default(now())
}

model MemorialService {
  id               String         @id @default(cuid())
  deceasedPersonId String
  deceasedPerson   DeceasedPerson @relation(fields: [deceasedPersonId], references: [id], onDelete: Cascade)

  type            String // "40MH", "1YEAR", "3YEARS", "OTHER"
  date            DateTime
  time            String?
  officiantPriest String?
  notes           String?

  createdAt DateTime @default(now())
}

// =======================
// KANONAS CONNECT (CITIZEN PORTAL)
// =======================

model CitizenRequest {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  type   String // e.g. "AGAMIAS", "GAMOU", "VAPTISIS", "VEVAIOSI", "KATHXITIKO", "EKDROMI"
  status String @default("PENDING") // INTERESTED, PENDING, CONFIRMED, REJECTED, DOCS_GENERATED, COMPLETED

  bookingSlotId String?  @unique
  bookingSlot   BookingSlot? @relation(fields: [bookingSlotId], references: [id], onDelete: SetNull)

  assignedPriestId String?
  assignedPriest   User? @relation(fields: [assignedPriestId], references: [id], onDelete: SetNull)

  protocolNumber String?
  templateAnswers String?
  generatedDocs   String? // JSON array of generated documents

  applicantName  String
  applicantEmail String?
  applicantPhone String?

  // Το σώμα της αίτησης δυναμικά
  payload String // JSON string with names, dates, requests

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PrayerRequest {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  parishionerId String? // Αν υποβλήθηκε από γνωστό ενορίτη
  parishioner   Parishioner? @relation(fields: [parishionerId], references: [id], onDelete: SetNull)

  submitterName  String?
  submitterEmail String?

  type        String // π.χ. "LITURGY", "PARAKLISI", "ARTOKLASIA", "MNIMOSYNO"
  livingNames String? // Υπέρ Υγείας
  fallenNames String? // Υπέρ Αναπαύσεως

  status         String @default("pending") // pending, read_at_altar
  donationAmount Float?

  requestedForDate DateTime?

  createdAt DateTime @default(now())
}

// =======================
// MINISTRIES & VOLUNTEERS (ΔΙΑΚΟΝΙΕΣ ΚΑΙ ΕΘΕΛΟΝΤΕΣ)
// =======================

model Ministry {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  name        String // e.g. "Καθαριότητα", "Συσσίτιο"
  description String?
  color       String? // hex for UI

  volunteers MinistryVolunteer[]
  shifts     Shift[]

  createdAt DateTime @default(now())
}

model Volunteer {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String
  phone     String?
  email     String?

  ministries MinistryVolunteer[]
  shifts     ShiftAssignment[]

  createdAt DateTime @default(now())
}

model MinistryVolunteer {
  id          String    @id @default(cuid())
  ministryId  String
  ministry    Ministry  @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  volunteerId String
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@unique([ministryId, volunteerId])
}

model Shift {
  id         String   @id @default(cuid())
  ministryId String
  ministry   Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)

  date      DateTime
  startTime String?
  endTime   String?
  notes     String?

  assignments ShiftAssignment[]
}

model ShiftAssignment {
  id      String @id @default(cuid())
  shiftId String
  shift   Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  volunteerId String
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  status String @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED

  @@unique([shiftId, volunteerId])
}

// =======================
// YOUTH & CAMP (ΝΕΟΛΑΙΑ & ΚΑΤΑΣΚΗΝΩΣΗ)
// =======================

model YouthProgram {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  name        String // e.g. "Κατασκήνωση Ιουλίου", "Κατηχητικό Δημοτικού"
  description String?
  startDate   DateTime?
  endDate     DateTime?

  enrollments ProgramEnrollment[]

  createdAt DateTime @default(now())
}

model YouthParticipant {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String
  birthDate DateTime?

  parentName  String?
  parentPhone String?
  parentEmail String?

  schoolGrade String? // Τάξη Σχολείου

  medicalNotes      String? // Αλλεργίες / Ιατρικό Ιστορικό
  parentConsentDate DateTime? // Ημερομηνία υπογραφής συναίνεσης

  enrollments ProgramEnrollment[]

  createdAt DateTime @default(now())
}

model ProgramEnrollment {
  id            String           @id @default(cuid())
  programId     String
  program       YouthProgram     @relation(fields: [programId], references: [id], onDelete: Cascade)
  participantId String
  participant   YouthParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  enrollmentDate DateTime @default(now())
  paymentStatus  String   @default("PENDING") // PENDING, PAID, FREE
  notes          String?

  @@unique([programId, participantId])
}

// =======================
// CENTRAL CALENDAR (ΚΕΝΤΡΙΚΟ ΗΜΕΡΟΛΟΓΙΟ)
// =======================

model CentralEvent {
  id String @id @default(cuid())

  metropolisId String? // If null, it's a completely global systemic event
  metropolis   Metropolis? @relation(fields: [metropolisId], references: [id], onDelete: Cascade)

  templeId String? // If null, it's a metropolis-wide event
  temple   Temple? @relation(fields: [templeId], references: [id], onDelete: Cascade)

  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  isPublic    Boolean  @default(true)
  category    String? // e.g. "ΛΕΙΤΟΥΡΓΙΑ", "ΣΥΝΕΔΡΙΟ", "ΚΑΤΑΣΚΗΝΩΣΗ"
  color       String? // Hex color for the calendar

  createdAt DateTime @default(now())
}

model BloodDrive {
  id       String @id @default(cuid())
  templeId String
  temple   Temple @relation(fields: [templeId], references: [id], onDelete: Cascade)

  name        String // e.g. Εαρινή Αιμοδοσία
  date        DateTime
  endDate     DateTime?
  location    String?
  target      Int?    // Στόχος σε φιάλες
  status      String  @default("PLANNED") // PLANNED, ACTIVE, COMPLETED, CANCELLED

  // Hospital Partner
  hospitalName    String?
  hospitalContact String?
  hospitalPhone   String?
  hospitalEmail   String?

  timeStart String? // "09:00"
  timeEnd   String? // "14:00"

  notes     String?
  donations    BloodDonation[]
  participants BloodDriveParticipant[]

  createdAt DateTime @default(now())
}

// =======================
// SISSITIO (ΣΥΣΣΙΤΙΟ - EXPANDED)
// =======================

model SissitioRecipient {
  id           String    @id @default(cuid())
  templeId     String
  temple       Temple    @relation(fields: [templeId], references: [id], onDelete: Cascade)

  firstName    String
  lastName     String
  fatherName   String?
  dateOfBirth  DateTime?
  gender       String?  // "M" | "F"
  afm          String?  @unique
  address      String?
  city         String?
  phone        String?
  email        String?
  category     String   @default("taktikos") // "taktikos" | "ektaktos" | "episkeptis"
  familyMembers Int     @default(1)
  isActive     Boolean  @default(true)
  registeredAt DateTime @default(now())
  notes        String?

  medicalProfile SissitioMedical?
  attendances    SissitioRecipientAttendance[]
  payments       SissitioPayment[]
  documents      SissitioDocument[]

  createdAt DateTime @default(now())
}

model SissitioMedical {
  id          String            @id @default(cuid())
  recipientId String            @unique
  recipient   SissitioRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  allergies    String?
  dietaryNeeds String? // χορτοφάγος, νηστεία, διαβήτης
  conditions   String?
  medications  String?
  doctorName   String?
  doctorPhone  String?
  notes        String?
}

model SissitioDocument {
  id          String            @id @default(cuid())
  recipientId String
  recipient   SissitioRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  docType    String // "aitisi" | "pistopoiitiko" | "tautotita" | "allo"
  fileName   String
  fileUrl    String?
  uploadedAt DateTime @default(now())
  notes      String?
}

model SissitioRecipientAttendance {
  id          String            @id @default(cuid())
  recipientId String
  recipient   SissitioRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  date          DateTime
  present       Boolean @default(true)
  absenceType   String? // "dikaiologimeni" | "adikaiologiti"
  absenceReason String?
  notes         String?

  @@unique([recipientId, date])
}

model SissitioPayment {
  id          String            @id @default(cuid())
  recipientId String
  recipient   SissitioRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  amount    Float
  month     Int    // 1-12
  year      Int
  method    String? // "cash" | "bank" | "dorean"
  paidAt    DateTime @default(now())
  receiptNo String?  // SIS-2025-001
  notes     String?
}

model SissitioMenu {
  id        String          @id @default(cuid())
  templeId  String
  temple    Temple          @relation(fields: [templeId], references: [id], onDelete: Cascade)

  weekStart DateTime
  notes     String?
  days      SissitioMenuDay[]
  createdAt DateTime @default(now())
}

model SissitioMenuDay {
  id          String       @id @default(cuid())
  menuId      String
  menu        SissitioMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  dayOfWeek   Int      // 1=Δευτέρα ... 7=Κυριακή
  date        DateTime
  firstCourse String?  // σούπα / ορεκτικό
  mainCourse  String?  // κυρίως
  salad       String?
  dessert     String?
  bread       Boolean  @default(true)
  isNistisimo Boolean  @default(false)
  notes       String?

  recipes SissitioMenuDayRecipe[]
}

model SissitioRecipe {
  id           String    @id @default(cuid())
  templeId     String
  temple       Temple    @relation(fields: [templeId], references: [id], onDelete: Cascade)

  name         String
  category     String // "kyrios" | "soupa" | "salata" | "epidorpio"
  servings     Int    @default(10)
  isNistisimo  Boolean @default(false)
  ingredients  String  @default("[]") // JSON: [{name, qty, unit}]
  instructions String?
  notes        String?
  createdAt    DateTime @default(now())

  menuDays SissitioMenuDayRecipe[]
  portions SissitioPortionRecipe[]
}

model SissitioMenuDayRecipe {
  id        String          @id @default(cuid())
  menuDayId String
  menuDay   SissitioMenuDay @relation(fields: [menuDayId], references: [id], onDelete: Cascade)
  recipeId  String
  recipe    SissitioRecipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model SissitioPortionLog {
  id            String    @id @default(cuid())
  templeId      String
  temple        Temple    @relation(fields: [templeId], references: [id], onDelete: Cascade)

  date          DateTime
  totalPortions Int
  servedPortions Int
  leftover      Int?
  notes         String?
  createdAt     DateTime @default(now())

  recipes SissitioPortionRecipe[]
}

model SissitioPortionRecipe {
  id           String             @id @default(cuid())
  portionLogId String
  portionLog   SissitioPortionLog @relation(fields: [portionLogId], references: [id], onDelete: Cascade)
  recipeId     String
  recipe       SissitioRecipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  portions     Int
}

model SissitioInventoryItem {
  id          String    @id @default(cuid())
  templeId    String
  temple      Temple    @relation(fields: [templeId], references: [id], onDelete: Cascade)

  name        String
  category    String // "kreatika" | "lahanika" | "bakalika" | "galaktokomika" | "alla"
  unit        String // "kg" | "lt" | "tem" | "kout"
  quantity    Float   @default(0)
  minQuantity Float?
  notes       String?
  updatedAt   DateTime @updatedAt

  movements SissitioInventoryMovement[]
}

model SissitioInventoryMovement {
  id       String                @id @default(cuid())
  itemId   String
  item     SissitioInventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  moveType String // "eisagogi" | "eksagogi" | "diorthosi"
  quantity Float
  date     DateTime @default(now())
  notes    String?
}

// =======================
// CAMPS (ΚΑΤΑΣΚΗΝΩΣΕΙΣ)
// =======================

model CampSession {
  id          String   @id @default(cuid())
  templeId    String
  temple      Temple   @relation(fields: [templeId], references: [id], onDelete: Cascade)
  
  name        String                          // π.χ. "Α΄ Περίοδος 2025"
  startDate   DateTime
  endDate     DateTime
  maxCapacity Int
  pricePerSlot Float     @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  campers     CampCamper[]
  staff       CampStaff[]
  groups      CampGroup[]
}

model CampGroup {
  id        String      @id @default(cuid())
  name      String                            // π.χ. "Ομάδα Άλφα"
  color     String?                           // hex color
  sessionId String
  session   CampSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  campers   CampCamper[]
}

model CampCamper {
  id              String      @id @default(cuid())
  templeId        String
  temple          Temple      @relation(fields: [templeId], references: [id], onDelete: Cascade)

  firstName       String
  lastName        String
  fatherName      String?
  motherName      String?
  dateOfBirth     DateTime
  gender          String                      // "M" | "F"
  address         String?
  city            String?
  phone           String?                     // τηλ. γονέα
  email           String?                     // email γονέα
  tshirtSize      String?                     // XS/S/M/L/XL/XXL
  tshirtColor     String?
  
  sessionId       String
  session         CampSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  groupId         String?
  group           CampGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  
  medicalInfo     CampMedical?
  payments        CampPayment[]
  attendances     CampAttendance[]
  consent         CampConsent?
  
  createdAt       DateTime    @default(now())
}

model CampMedical {
  id              String     @id @default(cuid())
  camperId        String     @unique
  camper          CampCamper @relation(fields: [camperId], references: [id], onDelete: Cascade)
  allergies       String?
  medications     String?
  conditions      String?
  doctorName      String?
  doctorPhone     String?
  bloodType       String?
  insuranceNumber String?
  notes           String?
}

model CampConsent {
  id              String     @id @default(cuid())
  camperId        String     @unique
  camper          CampCamper @relation(fields: [camperId], references: [id], onDelete: Cascade)
  parentName      String
  parentSignature String?                     // base64 ή URL
  signedAt        DateTime?
  photoConsent    Boolean    @default(false)
  medicalConsent  Boolean    @default(false)
}

model CampPayment {
  id          String     @id @default(cuid())
  camperId    String
  camper      CampCamper @relation(fields: [camperId], references: [id], onDelete: Cascade)
  amount      Float
  type        String                          // "prokatavoli" | "ypoloipo" | "oliko"
  method      String?                         // "cash" | "bank" | "card"
  paidAt      DateTime   @default(now())
  notes       String?
  receiptNo   String?
}

model CampStaff {
  id          String      @id @default(cuid())
  firstName   String
  lastName    String
  role        String                          // "symvoulos" | "iatros" | "mageiras" | "dieythyntis"
  phone       String?
  email       String?
  sessionId   String
  session     CampSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  assignedGroup String?
}

model CampAttendance {
  id          String     @id @default(cuid())
  camperId    String
  camper      CampCamper @relation(fields: [camperId], references: [id], onDelete: Cascade)
  date        DateTime
  present     Boolean    @default(true)
  notes       String?

  @@unique([camperId, date])
}

// =======================
// SYSTEM ANNOUNCEMENTS (Super Admin → All Temples)
// =======================

model SystemAnnouncement {
  id        String   @id @default(cuid())
  title     String
  body      String   // Rich text / markdown
  type      String   @default("info") // "info", "warning", "update", "maintenance"
  priority  String   @default("normal") // "low", "normal", "high"
  authorId  String?
  isActive  Boolean  @default(true)
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
