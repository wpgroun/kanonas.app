# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/kanonas_db"

# ─── JWT Authentication ────────────────────────────────────────────────────────
# REQUIRED in production. Generate with: openssl rand -base64 64
JWT_SECRET="change_me_use_a_long_random_string_at_least_64_chars"

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# ─── SMTP Email ────────────────────────────────────────────────────────────────
# Required for 2FA, ceremony reminders, and bulk emails.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@kanonas.gr"
SMTP_FROM_NAME="Κανόνας – Γραμματεία Ναού"

# ─── Payments – Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Payments – Viva Wallet (Greek market) ────────────────────────────────────
VIVA_CLIENT_ID=""
VIVA_CLIENT_SECRET=""
VIVA_SOURCE_CODE=""
VIVA_MERCHANT_ID=""

# ─── SMS – Yuboto ─────────────────────────────────────────────────────────────
YUBOTO_API_KEY=""
YUBOTO_SENDER_ID="KANONAS"

# ─── Web Push Notifications ───────────────────────────────────────────────────
# Generate keys with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@kanonas.gr"

# ─── Uploads ──────────────────────────────────────────────────────────────────
UPLOAD_DIR="./public/uploads"

# ─── Cron Jobs (Railway) ──────────────────────────────────────────────────────
# Random secret για να προστατεύεις τα cron endpoints
CRON_SECRET="change_me_random_secret"
NEXT_PUBLIC_BASE_URL="https://yourdomain.up.railway.app"
